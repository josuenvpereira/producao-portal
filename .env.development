# ── Portal de Produção — config de DESENVOLVIMENTO (versionada) ──────────────
# Arquivo SEM segredos, seguro p/ git. Carregado quando ENV_FILE=.env.development
# (é o que `npm run dev:mock` faz). NUNCA toca/poluí o `.env` de produção.
# Para sobrepor algo localmente sem editar este arquivo: crie `.env.local`
# (gitignored) — ele tem precedência. NÃO use este arquivo em produção.

# Servidor — dev local
PORT=8080
NODE_ENV=development
# Onde o navegador acessa a SPA (vite dev). /api é proxiado p/ :8080.
PUBLIC_ORIGIN=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
# Em dev (NODE_ENV!=production) a auth é opcional: sem hash, sobe com banner de
# aviso e sem exigir login. Para testar o fluxo de login, gere uma chave de
# DEV (node scripts/gen-portal-key.js) e ponha o hash no `.env.local`.
PORTAL_ACCESS_KEY_HASH=
PORTAL_COOKIE_SECRET=dev-insecure-cookie-secret-change-me
PORTAL_SESSION_TTL_S=43200

# ── GitHub (sem token em dev → adapter degrada sem crash) ────────────────────
GITHUB_TOKEN=
GITHUB_REPO=josuenvpereira/remotion_project
GITHUB_DEFAULT_BRANCH=main
GITHUB_WEBHOOK_SECRET=

# ── OpenClaw (sem exporter em dev → "sem dados", esperado) ───────────────────
OPENCLAW_EXPORT_DIR=./data/openclaw-export
DEEPSEEK_PRO_IN_USD_PER_1M=0
DEEPSEEK_PRO_OUT_USD_PER_1M=0
DEEPSEEK_FLASH_IN_USD_PER_1M=0
DEEPSEEK_FLASH_OUT_USD_PER_1M=0

# ── SFX Factory → MOCK LOCAL (scripts/sfx-mock.mjs) ──────────────────────────
# Casa desligada / sem WireGuard em dev: aponta pro mock (npm run dev:mock o
# sobe junto). Chave = default do mock; nada sensível.
SFX_BASE_URL=http://localhost:8099
SFX_API_KEY=dev-mock-key
SFX_CONNECT_TIMEOUT_S=5
SFX_READ_TIMEOUT_S=900

# ── Armazenamento local (read-model + vault, gitignored em data/) ────────────
DATA_DIR=./data
REPO_DIR=../
COST_MONTHLY_BUDGET_USD=30
