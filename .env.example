# ── Portal de Produção — exemplo de configuração ─────────────────────────────
# Copie para `.env` (NUNCA versionado). No VPS, espelha o padrão do OpenClaw
# (/docker/openclaw-0wr6/.env): segredo em arquivo, sem painel web.

# Servidor
PORT=8080
NODE_ENV=production
# Origem pública (usada p/ cookie Secure + CORS). Em prod: https://producao.jotaene.ia.br
PUBLIC_ORIGIN=https://producao.jotaene.ia.br

# ── Auth (chave única) ───────────────────────────────────────────────────────
# Gere com: node scripts/gen-portal-key.js  → cole o hash aqui (NÃO a chave).
PORTAL_ACCESS_KEY_HASH=
# Segredo p/ assinar o cookie de sessão (32+ bytes aleatórios).
# Gere: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
PORTAL_COOKIE_SECRET=
# TTL da sessão em segundos (deslizante). Default 12h.
PORTAL_SESSION_TTL_S=43200

# ── GitHub (fonte da verdade: repo + Actions render-ep.yml) ──────────────────
# PAT fine-grained READ-ONLY: Contents:read + Actions:read no repo.
GITHUB_TOKEN=
GITHUB_REPO=josuenvpereira/remotion_project
GITHUB_DEFAULT_BRANCH=main
# Secret do webhook (GitHub → Settings → Webhooks). Validação HMAC.
GITHUB_WEBHOOK_SECRET=

# ── OpenClaw (custo de tokens) ───────────────────────────────────────────────
OPENCLAW_USAGE_URL=https://claw.jotaene.ia.br/usage
# Se a página /usage exigir auth, cole aqui (formato definido na Fase 1).
OPENCLAW_USAGE_TOKEN=
# Snapshots do OpenClaw (gerados por scripts/openclaw-export.sh no host VPS,
# montados :ro). No container = /openclaw-export.
OPENCLAW_EXPORT_DIR=/openclaw-export
# Caminho NO HOST do dir de export (usado pelo docker-compose).
PORTAL_OPENCLAW_EXPORT_DIR=/docker/openclaw-0wr6/portal-export
# Preço DeepSeek (USD por 1M tokens) p/ estimar custo. 0 = só mostra tokens.
DEEPSEEK_PRO_USD_PER_1M=0
DEEPSEEK_FLASH_USD_PER_1M=0

# ── SFX Factory (geração de áudio — na casa, via WireGuard) ──────────────────
# Só o BACKEND fala com isso (chave nunca vai pro browser). O container precisa
# alcançar 10.8.0.2 (peer WireGuard do host) — validar no deploy.
SFX_BASE_URL=http://10.8.0.2:8000
SFX_API_KEY=
SFX_CONNECT_TIMEOUT_S=5
SFX_READ_TIMEOUT_S=900

# ── Armazenamento local (read-model + vault de artifacts) ───────────────────
DATA_DIR=./data
# Clone local do repo que o portal lê (git pull). Em dev pode apontar p/ a raiz.
REPO_DIR=../
# Teto mensal de custo (USD) p/ alertas no dashboard ("não me surpreender").
COST_MONTHLY_BUDGET_USD=30

# ── Deploy no VPS (docker-compose.yml) — só usado no host ───────────────────
# Rede externa do Traefik (a MESMA do container OpenClaw). Descubra com:
#   docker inspect openclaw-0wr6-openclaw-1 --format '{{json .NetworkSettings.Networks}}'
PORTAL_TRAEFIK_NETWORK=
# Nome do certresolver do Traefik (Let's Encrypt). Veja a config/labels do
# Traefik ou de outro serviço já publicado. Ex.: letsencrypt
PORTAL_TRAEFIK_CERTRESOLVER=letsencrypt
# Caminho NO HOST do repo que o supervisor (orquestrador_msu) opera — o portal
# monta read-only em /repo (pipeline-state/, public/, openclaw_workspaces/).
PORTAL_REPO_DIR=/docker/openclaw-0wr6/data/.openclaw/workspace-remotion
